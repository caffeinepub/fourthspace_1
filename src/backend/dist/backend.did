   milestoneId: EntityId) -> (variant {
                                err: text;
                                ok: EscrowMilestone;
                              });
  approveTransaction: (tenantId: TenantId, workspaceId: WorkspaceId, txId:
   EntityId, approved: bool) -> (variant {
                                   err: text;
                                   ok: WalletTransaction;
                                 });
  archiveProject: (tenantId: TenantId, workspaceId: WorkspaceId, id:
   EntityId) -> (variant {
                   err: text;
                   ok: Project;
                 });
  assignArbiter: (tenantId: TenantId, workspaceId: WorkspaceId, disputeId:
   EntityId, arbiter: principal) -> (variant {
                                       err: text;
                                       ok: EscrowDispute;
                                     });
  /// Bulk approve payroll records — sums all amounts and checks treasury balance once BEFORE approving.
  bulkApprovePayroll: (tenantId: TenantId, workspaceId: WorkspaceId,
