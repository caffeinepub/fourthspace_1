   EntityId, input: TaskCommentInput) ->
   (variant {
      err: text;
      ok: TaskComment;
    });
  addContractor: (tenantId: TenantId, workspaceId: WorkspaceId, input:
   ContractorInput) -> (variant {
                          err: text;
                          ok: Contractor;
                        });
  /// Add a contractor payment — requires sufficient treasury balance.
  addContractorPayment: (tenantId: TenantId, workspaceId: WorkspaceId, input:
   ContractorPaymentInput) -> (variant {
                                 err: text;
                                 ok: ContractorPayment;
                               });
  addDeduction: (tenantId: TenantId, workspaceId: WorkspaceId, input:
   DeductionInput) -> (variant {
                         err: text;
                         ok: Deduction;
                       });
  addEmployee: (tenantId: TenantId, workspaceId: WorkspaceId, input:
   EmployeeInput) -> (variant {
                        err: text;
                        ok: Employee;
                      });
  addEscrowMilestone: (tenantId: TenantId, workspaceId: WorkspaceId,
   escrowId: EntityId, input: EscrowMilestoneInput) ->
   (variant {
      err: text;
      ok: EscrowMilestone;
    });
  addIntegrationEvent: (tenantId: TenantId, workspaceId: WorkspaceId,
   integrationId: EntityId, eventType: text, payload: text) ->
   (variant {
      err: text;
      ok: IntegrationEvent;
    });
  addKeyResult: (tenantId: TenantId, workspaceId: WorkspaceId, input:
   KeyResultInput) -> (variant {
                         err: text;
                         ok: KeyResult;
                       });
  /// Add an off-cycle payment — requires non-zero treasury balance before processing.
  addOffCyclePayment: (tenantId: TenantId, workspaceId: WorkspaceId, input:
   OffCyclePaymentInput) -> (variant {
                               err: text;
                               ok: OffCyclePayment;
                             });
  addPaySchedule: (tenantId: TenantId, workspaceId: WorkspaceId, input:
   PayScheduleInput) -> (variant {
                           err: text;
                           ok: PaySchedule;
                         });
  addReaction: (tenantId: TenantId, workspaceId: WorkspaceId, messageId:
   EntityId, emoji: text) -> (variant {
                                err: text;
                                ok: Message;
                              });
  addTaskRelationship: (tenantId: TenantId, workspaceId: WorkspaceId,
   sourceTaskId: EntityId, targetTaskId: EntityId, relType:
   TaskRelationshipType) -> (variant {
                               err: text;
                               ok: TaskRelationship;
                             });
  addTaskToSprint: (tenantId: TenantId, workspaceId: WorkspaceId, sprintId:
   EntityId, taskId: EntityId) -> (variant {
                                     err: text;
                                     ok: Sprint;
                                   });
  addTaskWatcher: (tenantId: TenantId, workspaceId: WorkspaceId, taskId:
   EntityId, userId: UserId) -> (variant {
                                   err: text;
                                   ok: TaskWatcher;
                                 });
  addWorkspaceMember: (tenantId: TenantId, workspaceId: EntityId, userId:
   UserId, role: WorkspaceRole, displayName: text, email: text) ->
   (variant {
      err: text;
      ok: WorkspaceMember;
    });
