service : {
  acceptGuestInvitation: (tenantId: TenantId, workspaceId: WorkspaceId,
   token: text) -> (variant {
                      err: text;
                      ok: GuestUser;
                    });
  addBenefit: (tenantId: TenantId, workspaceId: WorkspaceId, input:
   BenefitInput) -> (variant {
                       err: text;
                       ok: Benefit;
                     });
  addChecklistItem: (tenantId: TenantId, workspaceId: WorkspaceId, input:
   ChecklistItemInput) -> (variant {
                             err: text;
                             ok: ChecklistItem;
                           });
